{
    "framework": {
        "default": {
            "language": "en",
            "route": [
                "info",
                "autoload",
                "parse",
                "cache",
                "data",
                "init",
                "install",
                "license",
                "linefeed",
                "ln",
                "version",
                "uuid",
                "password",
                "ramdisk",
                "rewrite",
                "bin",
                "zip",
                "reset",
                "update"
            ]
        },
        "name": "raxon/framework",
        "url": "https://raxon.org",
        "major": 2026,
        "minor": "06",
        "patch": "1233",
        "version": "2026.06.1233",
        "built": "2026-06-02 09:53:26"
    },
    "sourceType": [
      "wav",
      "ogg",
      "mp3",
      "png",
      "jpg",
      "bmp",
      "gif",
      "webp",
      "webm",
      "mp4"
    ],
    "extension": {
      "txt" : ".txt",
      "json": ".json",
      "php": ".php"
    },
    "error": {
        "extension": {
            "tpl": [
                "htm",
                "html",
                "php",
                "xml",
                "asp",
                "aspx",
                "pdf"
            ],
            "text": [
                "env",
                "txt",
                "log",
                "cgi"
            ],
            "js": [
                "js"
            ],
            "json": [
                "json"
            ]
        }
    },
    "cache" : {
        "autoload": {
            "url": {
                "name_length": 100,
                "name_separator": "_",
                "name_pop_or_shift": "shift",
                "directory_length": 75,
                "directory_separator": "/",
                "directory_pop_or_shift": "pop"
            }
        },
        "fileRequest": {
            "url" : {
                "name_length": 100,
                "name_separator": "_",
                "name_pop_or_shift": "shift",
                "directory_length": 75,
                "directory_separator": "_",
                "directory_pop_or_shift": "pop"
            }
        },
        "cache": {
            "url": {
                "name_length": 80,
                "name_separator": "-",
                "name_pop_or_shift": "shift"
            }
        },
        "controller": {
            "url": {
                "name_length": 175,
                "name_separator": "_",
                "name_pop_or_shift": "shift"
            },
            "ttl": 600
        },
        "parse": {
            "url": {
                "name_length": 175,
                "name_separator": "_",
                "name_pop_or_shift": "shift"
            },
            "plugin": {
                "url" : {
                    "name_length": 100,
                    "name_separator": "_",
                    "name_pop_or_shift": "shift",
                    "directory_length": 75,
                    "directory_separator": "_",
                    "directory_pop_or_shift": "pop"
                },
                "list" : [
                    {
                        "name": "require",
                        "name_length": 175,
                        "name_separator": "_",
                        "name_pop_or_shift": "shift"
                    }
                ]
            }
        }
    },
    "parse": {
        "prefix": "Raxon\\Module\\Compile",
        "read": {
            "parser": "{{RAX}}",
            "row_mismatch": 1,
            "object": {
                "use_this": true,
                "this": {
                    "parentNode": "#parentNode",
                    "rootNode": "#rootNode",
                    "attribute": "#attribute",
                    "key": "#key",
                    "url": "#url",
                    "parallel": "#parallel",
                    "output": "#output"
                },
                "#copy": {
                    "#key": "name--debug"
                }
            }
        },
        "plugin": {
            "parallel": {
                "thread": 96
            },
            "multi_line": [
                "block.code",
                "block.html",
                "block.json",
                "capture.prepend",
                "capture.append",
                "script",
                "trait"
            ],
            "literal": [
                {
                    "name": "unset",
                    "count": "*"
                },
                {
                    "name":  "array_current",
                    "count": 1
                },
                {
                    "name":  "array_cycle",
                    "count": 1
                },
                {
                    "name": "array_end",
                    "count": 1
                },
                {
                    "name": "array_next",
                    "count": 1
                },
                {
